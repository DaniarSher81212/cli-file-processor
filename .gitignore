# Виртуальное окружение — у каждого разработчика своё, не нужно в git
.venv/
venv/

# Файл с реальными настройками — у каждого свой, содержит приватные данные
.env

# Python-кеш — генерируется автоматически, не нужен в git
__pycache__/
*.pyc
*.pyo

# Метаданные установленного пакета — генерируются при pip install
*.egg-info/

# Кеш pytest
.pytest_cache/

# Данные — обрабатываемые файлы не часть кода
data/output/

# Системные файлы редакторов
.vscode/settings.json
.idea/
